import { TextEdit, Button, HorizontalBox, VerticalBox, ScrollView } from "std-widgets.slint";

export component NotepadWindow inherits Window {
    title: "Bloc de Notas";
    preferred-width: 800px;
    preferred-height: 600px;

    // Propiedades que Rust puede leer y escribir
    in-out property <string> content: "";
    in property <bool> can-undo: false;
    in property <bool> can-redo: false;

    // Callbacks que Rust escucha
    callback text-changed(string);
    callback undo-requested();
    callback redo-requested();

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        // Barra de herramientas
        Rectangle {
            height: 44px;
            background: #2d2d2d;

            HorizontalBox {
                padding-left: 8px;
                padding-right: 8px;
                padding-top: 6px;
                padding-bottom: 6px;
                spacing: 6px;
                alignment: start;

                Button {
                    text: "↩ Deshacer";
                    enabled: root.can-undo;
                    clicked => { root.undo-requested(); }
                }

                Button {
                    text: "↪ Rehacer";
                    enabled: root.can-redo;
                    clicked => { root.redo-requested(); }
                }

                // Separador visual
                Rectangle { width: 10px; }

                Text {
                    text: "Ctrl+Z = Deshacer  |  Ctrl+Y = Rehacer";
                    color: #aaaaaa;
                    font-size: 12px;
                    vertical-alignment: center;
                }
            }
        }

        // Área de texto principal
        TextEdit {
            text <=> root.content;
            font-size: 14px;
            edited(new-text) => {
                root.text-changed(new-text);
            }
        }
    }

    // Captura de atajos de teclado globales
    forward-focus: focus-scope;
    focus-scope := FocusScope {
        key-pressed(event) => {
            if (event.modifiers.control && event.text == "z") {
                root.undo-requested();
                return accept;
            }
            if (event.modifiers.control && event.text == "y") {
                root.redo-requested();
                return accept;
            }
            reject
        }
    }
}
